# 复制为 .env(已 gitignore,绝不提交)。

# === 数据源(强强联合)===
# FRED:利率/利差/实际利率/广义美元/VIX/月频宏观。免费 key:https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_32_char_fred_api_key_here
# Twelve Data:黄金现货 XAU/USD(免费 https://twelvedata.com/)
TWELVEDATA_API_KEY=
# Tiingo:UUP(窄口径美元代理)/ SPY·QQQ(长历史)(免费 https://www.tiingo.com/)
TIINGO_API_TOKEN=

# === M1 智能平面 — LLM provider(任配一个即可;都不配则只产出事实层)===
# 显式选哪家;留空则按下面存在的 key 自动探测
# (顺序 anthropic>openai>minimax>deepseek>moonshot>zhipu>openai-compat)
LLM_PROVIDER=
# Anthropic(Claude)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=          # 默认 claude-sonnet-4-6,深度可设 claude-opus-4-8
# OpenAI(ChatGPT)
OPENAI_API_KEY=
OPENAI_MODEL=            # 默认 gpt-4o-mini
# MiniMax / DeepSeek / Moonshot(Kimi) / 智谱 —— 同为 OpenAI 兼容端点,各填自己的 key
MINIMAX_API_KEY=
DEEPSEEK_API_KEY=
MOONSHOT_API_KEY=
ZHIPU_API_KEY=
# 预设的域名/模型会随各家更新而变化:失败时用 <NAME>_BASE_URL / <NAME>_MODEL 覆盖
# 例:MINIMAX_BASE_URL=https://api.minimaxi.com/v1/text/chatcompletion_v2  MINIMAX_MODEL=MiniMax-M2
# 任意 OpenAI 兼容端点(自建/其他家):设 LLM_PROVIDER=openai-compat,再填下面三项
LLM_BASE_URL=            # 完整 chat/completions URL
LLM_API_KEY=
LLM_MODEL=

# === 交付:飞书机器人(均可选;不配则只存本地 md)===
FEISHU_WEBHOOK=
FEISHU_SECRET=           # 开启「签名校验」时填
