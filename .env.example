# 复制为 .env(已 gitignore,绝不提交)。

# === M0 数据平面 ===
# 申请免费 key:https://fred.stlouisfed.org/docs/api/api_key.html(32 位小写字母数字)
FRED_API_KEY=your_32_char_fred_api_key_here

# === M1 智能平面(均可选)===
# 生成 AI 四层简报需 Anthropic key;缺失则只产出事实层。
ANTHROPIC_API_KEY=
# 可选:默认 claude-sonnet-4-6,深度分析可设 claude-opus-4-8
ANTHROPIC_MODEL=
# 飞书自定义机器人 webhook(配了才推送;否则只存本地 md)
FEISHU_WEBHOOK=
# 飞书机器人「签名校验」密钥(开启签名时填)
FEISHU_SECRET=
